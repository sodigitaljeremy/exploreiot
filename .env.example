# ─── Database ─────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=exploreiot
DB_USER=exploreiot
DB_PASSWORD=change_me_in_production

# ─── MQTT Broker ──────────────────────────────────────────────
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USER=exploreiot
MQTT_PASSWORD=exploreiot_mqtt

# MQTT TLS (optional - set to true to enable encrypted connections)
# MQTT_TLS=false
# MQTT_CA_CERTS=/path/to/ca.crt

# ─── Frontend (baked at build time — rebuild after changes) ──
# URL de l'API FastAPI vue depuis le navigateur
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ─── CORS (origine autorisee pour l'API) ────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Environment (development | production) ─────────────────
# production enforces API_KEY, strong passwords, etc.
ENVIRONMENT=development

# ─── Data retention (auto-purge des anciennes mesures) ───────
DATA_RETENTION_DAYS=90

# ─── Alertes (seuils configurables) ──────────────────────────
ALERT_TEMP_THRESHOLD=33
ALERT_SILENCE_MINUTES=10

# ─── Authentification (optionnel, vide = pas d'auth) ─────────
API_KEY=
NEXT_PUBLIC_API_KEY=

# ─── pgAdmin (interface web PostgreSQL) ────────────────────
PGADMIN_EMAIL=admin@exploreiot.dev
PGADMIN_PASSWORD=admin

# ─── Docker port bindings (Coolify/VPS: use 0.0.0.0) ────────
# API_PORT=127.0.0.1:8000
# WEB_PORT=127.0.0.1:3000

# ─── WebSocket ────────────────────────────────────────────────
MAX_WS_CONNECTIONS=50

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_DEFAULT=30/minute

# ─── Chirpstack v4 (optionnel, profile Docker chirpstack) ────
CHIRPSTACK_ENABLED=false
CHIRPSTACK_API_URL=localhost:8080
CHIRPSTACK_API_KEY=

# ─── TTN - The Things Network (optionnel) ───────────────────
# Decommenter et remplir quand un compte TTN est disponible
# TTN_ENABLED=false
# TTN_MQTT_HOST=eu1.cloud.thethings.network
# TTN_MQTT_PORT=1883
# TTN_APP_ID=your-ttn-app-id
# TTN_ACCESS_KEY=NNSXS.your-access-key
# TTN_TENANT=ttn
